# MongoDB URI from Atlas or local
MONGO_URI=mongodb://localhost:27017/shirtify

# JWT secret
JWT_SECRET=your_jwt_secret_here
JWT_RESET_SECRET=your_jwt_reset_secret_here

# App port
PORT=5000

# Node environment (development or production)
NODE_ENV=development

# Frontend password reset page
RESET_PASSWORD_PAGE_URL=http://localhost:5173/frontend/reset-password/reset-password.html

# SMTP email settings for forgot-password links
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASS=your_app_password
SMTP_FROM=Shirtify <your_email@example.com>

# Payment gateway settings
# ===== TEST CREDENTIALS (For development/testing only) =====
# Set PAYMENT_TEST_MODE=true to auto-approve all payments without calling external APIs
PAYMENT_TEST_MODE=true
JAZZCASH_API_URL=https://sandbox.jazzcash.com.pk/ApplicationAPI/API/2.0/OnlineCheckout
JAZZCASH_MERCHANT_ID=TESTMERCHANT
JAZZCASH_PASSWORD=TestPassword123
JAZZCASH_INTEGERITY_SALT=TestSalt12345
JAZZCASH_SUBMERCHANT_ID=
JAZZCASH_TXN_TYPE=MWALLET
EASYPAISA_MODE=mock

# ===== PRODUCTION CREDENTIALS (Replace with your actual credentials after deployment) =====
# Contact JazzCash at: https://jazzcash.com.pk/merchants/
# Easypaisa at: https://www.easypaisa.com.pk/
# Once you have live credentials, update the above values
# Also set NODE_ENV=production and PAYMENT_TEST_MODE=false
